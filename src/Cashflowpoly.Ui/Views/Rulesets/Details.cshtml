@* Fungsi file: Merender tampilan Razor untuk bagian Rulesets/Details.cshtml beserta interaksi presentasinya. *@
@model Cashflowpoly.Ui.Models.RulesetDetailViewModel
@using System.Text.Json

@{
    ViewData["Title"] = Context.T("rulesets.detail_title");
    var isInstructor = Context.Session.IsInstructor();
    var showVersionActions = isInstructor && !Model.IsReadOnly;
}

@functions {
    private static JsonElement? GetPath(JsonElement root, params string[] path)
    {
        var cursor = root;
        foreach (var segment in path)
        {
            if (cursor.ValueKind != JsonValueKind.Object || !cursor.TryGetProperty(segment, out var next))
            {
                return null;
            }

            cursor = next;
        }

        return cursor;
    }

    private static string AsText(JsonElement? value, string fallback = "-")
    {
        if (!value.HasValue)
        {
            return fallback;
        }

        var v = value.Value;
        return v.ValueKind switch
        {
            JsonValueKind.String => v.GetString() ?? fallback,
            JsonValueKind.Number => v.ToString(),
            JsonValueKind.True => "true",
            JsonValueKind.False => "false",
            _ => v.ToString()
        };
    }

    private static int AsInt(JsonElement? value, int fallback = 0)
    {
        if (!value.HasValue || value.Value.ValueKind != JsonValueKind.Number)
        {
            return fallback;
        }

        return value.Value.TryGetInt32(out var number) ? number : fallback;
    }

    private static bool AsBool(JsonElement? value, bool fallback = false)
    {
        if (!value.HasValue)
        {
            return fallback;
        }

        return value.Value.ValueKind switch
        {
            JsonValueKind.True => true,
            JsonValueKind.False => false,
            _ => fallback
        };
    }

    private static string FormatJsonLeafValue(JsonElement element)
    {
        return element.ValueKind switch
        {
            JsonValueKind.String => element.GetString() ?? string.Empty,
            JsonValueKind.True => "true",
            JsonValueKind.False => "false",
            JsonValueKind.Number => element.GetRawText(),
            JsonValueKind.Null => "null",
            _ => element.GetRawText()
        };
    }

    private static List<(string Path, string Value)> FlattenJsonLeaves(JsonElement? root)
    {
        var rows = new List<(string Path, string Value)>();
        if (!root.HasValue)
        {
            return rows;
        }

        static void Visit(JsonElement element, string path, List<(string Path, string Value)> output)
        {
            switch (element.ValueKind)
            {
                case JsonValueKind.Object:
                    foreach (var property in element.EnumerateObject())
                    {
                        var nextPath = string.IsNullOrWhiteSpace(path)
                            ? property.Name
                            : $"{path}.{property.Name}";
                        Visit(property.Value, nextPath, output);
                    }

                    break;
                case JsonValueKind.Array:
                {
                    var index = 0;
                    foreach (var item in element.EnumerateArray())
                    {
                        Visit(item, $"{path}[{index}]", output);
                        index++;
                    }

                    break;
                }
                default:
                    output.Add((string.IsNullOrWhiteSpace(path) ? "value" : path, FormatJsonLeafValue(element)));
                    break;
            }
        }

        Visit(root.Value, string.Empty, rows);
        return rows;
    }
}

<section class="section-shell">
    <div class="page-intro">
        <div class="page-intro-main">
            <p class="eyebrow">@Context.T("rulesets.management")</p>
            <h1 class="headline">@Context.T("rulesets.detail_title")</h1>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="mt-4 alert alert-error" aria-live="polite">
            @Model.ErrorMessage
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.InfoMessage))
    {
        <div class="mt-4 alert alert-info" aria-live="polite">
            @Model.InfoMessage
        </div>
    }

    @if (Model.Ruleset is null)
    {
        <div class="mt-4 ruleset-unified">
            <div class="metric-panel">
                <p class="text-sm font-semibold text-slate-800">@Context.T("rulesets.detail.empty_title")</p>
                <p class="mt-2 text-sm text-slate-600">@Context.T("rulesets.detail.empty_body")</p>
                <div class="mt-4">
                    <a class="btn-ghost" asp-controller="Rulesets" asp-action="Index">@Context.T("rulesets.back_to_list")</a>
                </div>
            </div>
        </div>
    }
    else
    {
        var hasConfig = Model.Ruleset.ConfigJson.HasValue && Model.Ruleset.ConfigJson.Value.ValueKind == JsonValueKind.Object;
        var cfg = hasConfig ? Model.Ruleset.ConfigJson!.Value : default;
        var latestVersion = Model.Ruleset.Versions.Count > 0 ? Model.Ruleset.Versions.Max(v => v.Version) : 0;
        var activeVersionCount = Model.Ruleset.Versions.Count(v => string.Equals(v.Status, "ACTIVE", StringComparison.OrdinalIgnoreCase));

        <div class="mt-4 ruleset-unified ruleset-detail-shell">
            <div class="ruleset-detail-hero">
                <div class="ruleset-title-block">
                    <p class="text-sm text-slate-600">@Context.T("common.name")</p>
                    <p class="text-lg font-semibold text-slate-900">@Model.Ruleset.Name</p>
                    <p class="mt-2 text-sm text-slate-600">@Context.T("common.description")</p>
                    <p class="text-sm text-slate-700">@(string.IsNullOrWhiteSpace(Model.Ruleset.Description) ? "-" : Model.Ruleset.Description)</p>
                </div>
                <div class="ruleset-detail-meta">
                    <span class="status-pill status-active">
                        @Context.T("rulesets.status.available")
                    </span>
                    @if (Model.IsDefaultCatalogSource)
                    {
                        <span class="hint-chip">@Context.T("rulesets.detail.source_default_catalog")</span>
                    }
                    <p class="ruleset-detail-id-label">@Context.T("common.ruleset_id")</p>
                    <span class="id-chip">@Model.Ruleset.RulesetId</span>
                </div>
            </div>

            <div class="action-toolbar mt-4 ruleset-detail-toolbar">
                <a class="btn-ghost" asp-controller="Rulesets" asp-action="Index">@Context.T("rulesets.back_to_list")</a>
                @if (showVersionActions)
                {
                    <a class="btn-ghost"
                       asp-controller="Rulesets"
                       asp-action="Edit"
                       asp-route-rulesetId="@Model.Ruleset.RulesetId">@Context.T("rulesets.edit")</a>
                    <form method="post" asp-controller="Rulesets" asp-action="Delete" asp-route-rulesetId="@Model.Ruleset.RulesetId">
                        @Html.AntiForgeryToken()
                        <button class="btn-primary" type="submit">@Context.T("rulesets.delete")</button>
                    </form>
                }
                else
                {
                    <span class="hint-chip">@Context.T("rulesets.readonly_hint")</span>
                }
            </div>

            <div class="ruleset-detail-guide-shell mt-4" aria-label="@Context.T("rulesets.detail.guide_title")">
                <p class="ruleset-detail-guide-title">@Context.T("rulesets.detail.guide_title")</p>
                <ol class="ruleset-detail-guide">
                    <li>@Context.T("rulesets.detail.guide_step_identity")</li>
                    <li>@Context.T("rulesets.detail.guide_step_versions")</li>
                    <li>@Context.T("rulesets.detail.guide_step_components")</li>
                    <li>@Context.T("rulesets.detail.guide_step_config")</li>
                </ol>
            </div>

            <div class="ruleset-overview-grid mt-4">
                <article class="ruleset-overview-card">
                    <p class="ruleset-overview-label">@Context.T("rulesets.total_versions")</p>
                    <p class="ruleset-overview-value">@Model.Ruleset.Versions.Count</p>
                </article>
                <article class="ruleset-overview-card">
                    <p class="ruleset-overview-label">@Context.T("rulesets.active_versions")</p>
                    <p class="ruleset-overview-value">@activeVersionCount</p>
                </article>
                <article class="ruleset-overview-card">
                    <p class="ruleset-overview-label">@Context.T("common.latest_version")</p>
                    <p class="ruleset-overview-value">@(latestVersion > 0 ? $"v{latestVersion}" : "-")</p>
                </article>
                <article class="ruleset-overview-card">
                    <p class="ruleset-overview-label">@Context.T("rulesets.status_label")</p>
                    <p class="ruleset-overview-value">@Context.T("rulesets.status.available")</p>
                </article>
            </div>

            <section class="ruleset-detail-section mt-5">
                <div class="ruleset-section-head">
                    <p class="ruleset-section-title">@Context.T("rulesets.version_history")</p>
                    <p class="ruleset-section-subtitle">@Context.T("rulesets.version_history_subtitle")</p>
                </div>
                <div class="mt-3 table-wrap">
                <table class="w-full text-left text-sm">
                    <thead class="table-head">
                        <tr>
                            <th class="px-4 py-3">@Context.T("common.version")</th>
                            <th class="px-4 py-3">@Context.T("common.status")</th>
                            <th class="px-4 py-3">@Context.T("common.created")</th>
                            @if (showVersionActions)
                            {
                                <th class="px-4 py-3 text-right">@Context.T("common.action")</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                    @if (Model.Ruleset.Versions.Count == 0)
                    {
                        <tr>
                            <td class="px-4 py-4 text-slate-500" colspan="@(showVersionActions ? 4 : 3)">@Context.T("state.no_versions")</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var version in Model.Ruleset.Versions.OrderByDescending(v => v.Version))
                        {
                            <tr class="border-t border-slate-200">
                                <td class="px-4 py-3 font-medium text-slate-900">@($"v{version.Version}")</td>
                                <td class="px-4 py-3 text-slate-600">
                                    @{
                                        var statusClass = string.Equals(version.Status, "ACTIVE", StringComparison.OrdinalIgnoreCase)
                                            ? "status-active"
                                            : string.Equals(version.Status, "DRAFT", StringComparison.OrdinalIgnoreCase)
                                                ? "status-draft"
                                                : "status-retired";
                                    }
                                    <span class="status-pill @statusClass">@Context.TRulesetStatus(version.Status)</span>
                                </td>
                                <td class="px-4 py-3 text-slate-600">@version.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                @if (showVersionActions)
                                {
                                    <td class="px-4 py-3 text-right">
                                        @if (!string.Equals(version.Status, "ACTIVE", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <div class="inline-flex items-center gap-2">
                                                <form method="post"
                                                      asp-controller="Rulesets"
                                                      asp-action="ActivateVersion"
                                                      asp-route-rulesetId="@Model.Ruleset.RulesetId"
                                                      asp-route-version="@version.Version">
                                                    @Html.AntiForgeryToken()
                                                    <button class="btn-ghost btn-compact" type="submit">@Context.T("rulesets.set_active")</button>
                                                </form>
                                                <form method="post"
                                                      asp-controller="Rulesets"
                                                      asp-action="DeleteVersion"
                                                      asp-route-rulesetId="@Model.Ruleset.RulesetId"
                                                      asp-route-version="@version.Version"
                                                      onsubmit="return confirm('@Context.T("rulesets.delete_version_confirm")');">
                                                    @Html.AntiForgeryToken()
                                                    <button class="btn-ghost btn-compact" type="submit">@Context.T("rulesets.delete_version")</button>
                                                </form>
                                            </div>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    }
                    </tbody>
                </table>
                </div>
            </section>

            <section class="ruleset-detail-section mt-5">
                <div class="ruleset-section-head">
                    <p class="ruleset-section-title">@Context.T("rulesets.components.title")</p>
                    <p class="ruleset-section-subtitle">@Context.T("rulesets.components.subtitle_detail")</p>
                </div>
                <p class="mt-1 text-xs text-slate-500">@Context.T("rulesets.components.subtitle")</p>

                @if (!string.IsNullOrWhiteSpace(Model.ComponentsErrorMessage))
                {
                    <div class="mt-2 alert alert-error" aria-live="polite">
                        @Model.ComponentsErrorMessage
                    </div>
                }

                @{
                    var componentCatalog = Model.Components?.ComponentCatalog;
                    var hasComponentCatalog = componentCatalog.HasValue;
                    var componentRows = FlattenJsonLeaves(componentCatalog);
                    var localizedComponentRows = componentRows
                        .Select(row =>
                        {
                            var normalizedValue = row.Value.Trim();
                            var localizedValue = normalizedValue switch
                            {
                                var text when string.Equals(text, "true", StringComparison.OrdinalIgnoreCase) => Context.T("state.true"),
                                var text when string.Equals(text, "false", StringComparison.OrdinalIgnoreCase) => Context.T("state.false"),
                                var text when string.Equals(text, "null", StringComparison.OrdinalIgnoreCase) => Context.T("state.null"),
                                _ => row.Value
                            };

                            return (row.Path, Value: localizedValue);
                        })
                        .ToList();
                }

                @if (Model.Components is not null)
                {
                    <div class="ruleset-overview-grid mt-3">
                        <article class="ruleset-overview-card">
                            <p class="ruleset-overview-label">@Context.T("common.mode")</p>
                            <p class="ruleset-overview-value">@Context.TRulesetMode(Model.Components.Mode)</p>
                        </article>
                        <article class="ruleset-overview-card">
                            <p class="ruleset-overview-label">@Context.T("common.version")</p>
                            <p class="ruleset-overview-value">@($"v{Model.Components.Version}")</p>
                        </article>
                        <article class="ruleset-overview-card">
                            <p class="ruleset-overview-label">@Context.T("rulesets.components.ruleset_version_id")</p>
                            <p class="ruleset-overview-value font-mono text-xs">@Model.Components.RulesetVersionId</p>
                        </article>
                        <article class="ruleset-overview-card">
                            <p class="ruleset-overview-label">@Context.T("rulesets.components.item_count")</p>
                            <p class="ruleset-overview-value">@localizedComponentRows.Count</p>
                        </article>
                    </div>
                }

                @if (!hasComponentCatalog)
                {
                    <div class="mt-3 alert alert-info">
                        @Context.T("rulesets.components.unavailable")
                    </div>
                }
                else
                {
                    <div class="mt-3 table-wrap">
                        <table class="w-full text-left text-sm mobile-card-table">
                            <thead class="table-head">
                                <tr>
                                    <th class="px-4 py-3">@Context.T("common.path")</th>
                                    <th class="px-4 py-3">@Context.T("common.value")</th>
                                </tr>
                            </thead>
                            <tbody>
                            @if (localizedComponentRows.Count == 0)
                            {
                                <tr>
                                    <td class="px-4 py-4 text-slate-500 mobile-card-empty" colspan="2">
                                        @Context.T("rulesets.components.empty")
                                    </td>
                                </tr>
                            }
                            else
                            {
                                foreach (var row in localizedComponentRows)
                                {
                                    <tr class="border-t border-slate-200">
                                        <td class="px-4 py-3 font-mono text-xs text-slate-600" data-label="@Context.T("common.path")">@row.Path</td>
                                        <td class="px-4 py-3 text-slate-700" data-label="@Context.T("common.value")">@row.Value</td>
                                    </tr>
                                }
                            }
                            </tbody>
                        </table>
                    </div>

                    <details class="mt-3 data-toggle">
                        <summary>@Context.T("rulesets.components.raw_json")</summary>
                        <pre class="mt-2 overflow-x-auto rounded-lg border border-slate-200 bg-slate-50 p-3 text-xs text-slate-700">@JsonSerializer.Serialize(componentCatalog!.Value, new JsonSerializerOptions { WriteIndented = true })</pre>
                    </details>
                }
            </section>

            <section class="ruleset-detail-section mt-5">
                <div class="ruleset-section-head">
                    <p class="ruleset-section-title">@Context.T("rulesets.config_summary")</p>
                    <p class="ruleset-section-subtitle">@Context.T("rulesets.config_summary_subtitle")</p>
                </div>
                @if (!hasConfig)
                {
                    <div class="mt-2 alert alert-info">
                        @Context.T("rulesets.config_unavailable")
                    </div>
                }
                else
                {
                    var modeRaw = AsText(GetPath(cfg, "mode"), "PEMULA");
                    var modeLabel = Context.TRulesetMode(modeRaw);
                    var playerOrderingRaw = AsText(GetPath(cfg, "player_ordering"), "JOIN_ORDER");
                    var playerOrderingLabel = playerOrderingRaw.ToUpperInvariant() switch
                    {
                        "INSTRUCTOR_ORDER" or "MANUAL_ORDER" => Context.T("rulesets.form.player_ordering_instructor_order"),
                        "EVENT_SEQUENCE" => Context.T("rulesets.form.player_ordering_event_sequence"),
                        "PLAYER_ID" => Context.T("rulesets.form.player_ordering_player_id"),
                        "USERNAME" or "IDN" or "USERNAME_IDN" => Context.T("rulesets.form.player_ordering_username"),
                        _ => Context.T("rulesets.form.player_ordering_join_order")
                    };
                    var instructorPlayerUsernames = new List<string>();
                    var instructorSlotsElement = GetPath(cfg, "instructor_player_usernames");
                    if (instructorSlotsElement.HasValue && instructorSlotsElement.Value.ValueKind == JsonValueKind.Array)
                    {
                        foreach (var item in instructorSlotsElement.Value.EnumerateArray())
                        {
                            if (instructorPlayerUsernames.Count >= 4)
                            {
                                break;
                            }

                            instructorPlayerUsernames.Add(item.ValueKind == JsonValueKind.String
                                ? item.GetString() ?? string.Empty
                                : string.Empty);
                        }
                    }

                    while (instructorPlayerUsernames.Count < 4)
                    {
                        instructorPlayerUsernames.Add(string.Empty);
                    }

                    <div class="mt-3 space-y-4">
                        <div class="alert alert-info text-sm text-slate-700">
                            @Context.T("rulesets.config_read_guide")
                        </div>

                        <div class="ruleset-form-section">
                            <h3>@Context.T("rulesets.form.core_setup")</h3>
                            <p class="mt-1 text-xs text-slate-500">@Context.T("rulesets.form.help.core_setup")</p>
                            <div class="grid gap-3 md:grid-cols-2 mt-3">
                                <div>
                                    <label class="form-label">@Context.T("rulesets.form.mode")</label>
                                    <input type="text"
                                           readonly
                                           value="@modeLabel"
                                           class="form-input" />
                                </div>
                                <div>
                                    <label class="form-label">@Context.T("rulesets.form.actions_per_turn")</label>
                                    <input type="number"
                                           readonly
                                           value="@AsInt(GetPath(cfg, "actions_per_turn"), 2)"
                                           class="form-input" />
                                </div>
                                <div>
                                    <label class="form-label">@Context.T("rulesets.form.starting_cash")</label>
                                    <input type="number"
                                           readonly
                                           value="@AsInt(GetPath(cfg, "starting_cash"), 20)"
                                           class="form-input" />
                                </div>
                                <div>
                                    <label class="form-label">@Context.T("rulesets.form.player_ordering")</label>
                                    <input type="text"
                                           readonly
                                           value="@($"{playerOrderingLabel} ({playerOrderingRaw})")"
                                           class="form-input" />
                                </div>
                                <div class="md:col-span-2">
                                    <label class="form-label">@Context.T("rulesets.form.player_slots_title")</label>
                                    <div class="grid gap-3 md:grid-cols-2 mt-2">
                                        <div>
                                            <label class="form-label">@Context.T("rulesets.form.player_slot_1_username")</label>
                                            <input type="text"
                                                   readonly
                                                   value="@(string.IsNullOrWhiteSpace(instructorPlayerUsernames[0]) ? "-" : instructorPlayerUsernames[0])"
                                                   class="form-input" />
                                        </div>
                                        <div>
                                            <label class="form-label">@Context.T("rulesets.form.player_slot_2_username")</label>
                                            <input type="text"
                                                   readonly
                                                   value="@(string.IsNullOrWhiteSpace(instructorPlayerUsernames[1]) ? "-" : instructorPlayerUsernames[1])"
                                                   class="form-input" />
                                        </div>
                                        <div>
                                            <label class="form-label">@Context.T("rulesets.form.player_slot_3_username")</label>
                                            <input type="text"
                                                   readonly
                                                   value="@(string.IsNullOrWhiteSpace(instructorPlayerUsernames[2]) ? "-" : instructorPlayerUsernames[2])"
                                                   class="form-input" />
                                        </div>
                                        <div>
                                            <label class="form-label">@Context.T("rulesets.form.player_slot_4_username")</label>
                                            <input type="text"
                                                   readonly
                                                   value="@(string.IsNullOrWhiteSpace(instructorPlayerUsernames[3]) ? "-" : instructorPlayerUsernames[3])"
                                                   class="form-input" />
                                        </div>
                                    </div>
                                </div>
                                <div>
                                    <label class="form-label">@Context.T("rulesets.form.freelance_income")</label>
                                    <input type="number"
                                           readonly
                                           value="@AsInt(GetPath(cfg, "freelance", "income"), 1)"
                                           class="form-input" />
                                </div>
                            </div>
                        </div>

                        <div class="ruleset-form-section">
                            <h3>@Context.T("rulesets.form.weekday_features")</h3>
                            <p class="mt-1 text-xs text-slate-500">@Context.T("rulesets.form.help.weekday_features")</p>
                            <div class="grid gap-3 md:grid-cols-3 mt-3">
                                <label class="metric-row"><span class="metric-key">@Context.T("rulesets.form.friday_donation")</span><input type="checkbox" disabled @(AsBool(GetPath(cfg, "weekday_rules", "friday", "enabled"), true) ? "checked" : null) /></label>
                                <label class="metric-row"><span class="metric-key">@Context.T("rulesets.form.saturday_gold_trade")</span><input type="checkbox" disabled @(AsBool(GetPath(cfg, "weekday_rules", "saturday", "enabled"), true) ? "checked" : null) /></label>
                                <label class="metric-row"><span class="metric-key">@Context.T("rulesets.form.sunday_rest")</span><input type="checkbox" disabled @(AsBool(GetPath(cfg, "weekday_rules", "sunday", "enabled"), true) ? "checked" : null) /></label>
                            </div>
                        </div>

                        <div class="ruleset-form-section">
                            <h3>@Context.T("rulesets.form.constraints")</h3>
                            <p class="mt-1 text-xs text-slate-500">@Context.T("rulesets.form.help.constraints")</p>
                            <div class="grid gap-3 md:grid-cols-2 mt-3">
                                <div>
                                    <label class="form-label">@Context.T("rulesets.form.cash_min")</label>
                                    <input type="number"
                                           readonly
                                           value="@AsInt(GetPath(cfg, "constraints", "cash_min"), 0)"
                                           class="form-input" />
                                </div>
                                <div>
                                    <label class="form-label">@Context.T("rulesets.form.max_ingredient_total")</label>
                                    <input type="number"
                                           readonly
                                           value="@AsInt(GetPath(cfg, "constraints", "max_ingredient_total"), 6)"
                                           class="form-input" />
                                </div>
                                <div>
                                    <label class="form-label">@Context.T("rulesets.form.max_same_ingredient")</label>
                                    <input type="number"
                                           readonly
                                           value="@AsInt(GetPath(cfg, "constraints", "max_same_ingredient"), 3)"
                                           class="form-input" />
                                </div>
                                <div>
                                    <label class="form-label">@Context.T("rulesets.form.primary_need_max_day")</label>
                                    <input type="number"
                                           readonly
                                           value="@AsInt(GetPath(cfg, "constraints", "primary_need_max_per_day"), 1)"
                                           class="form-input" />
                                </div>
                                <label class="metric-row md:col-span-2"><span class="metric-key">@Context.T("rulesets.form.require_primary_first")</span><input type="checkbox" disabled @(AsBool(GetPath(cfg, "constraints", "require_primary_before_others"), true) ? "checked" : null) /></label>
                            </div>
                        </div>

                        <div class="ruleset-form-section">
                            <h3>@Context.T("rulesets.form.economy_advanced")</h3>
                            <p class="mt-1 text-xs text-slate-500">@Context.T("rulesets.form.help.economy_advanced")</p>
                            <div class="grid gap-3 md:grid-cols-2 mt-3">
                                <div>
                                    <label class="form-label">@Context.T("rulesets.form.donation_min")</label>
                                    <input type="number"
                                           readonly
                                           value="@AsInt(GetPath(cfg, "donation", "min_amount"), 1)"
                                           class="form-input" />
                                </div>
                                <div>
                                    <label class="form-label">@Context.T("rulesets.form.donation_max")</label>
                                    <input type="number"
                                           readonly
                                           value="@AsInt(GetPath(cfg, "donation", "max_amount"), 999999)"
                                           class="form-input" />
                                </div>
                                <label class="metric-row"><span class="metric-key">@Context.T("rulesets.form.gold_buy")</span><input type="checkbox" disabled @(AsBool(GetPath(cfg, "gold_trade", "allow_buy"), true) ? "checked" : null) /></label>
                                <label class="metric-row"><span class="metric-key">@Context.T("rulesets.form.gold_sell")</span><input type="checkbox" disabled @(AsBool(GetPath(cfg, "gold_trade", "allow_sell"), true) ? "checked" : null) /></label>
                                <label class="metric-row"><span class="metric-key">@Context.T("rulesets.form.loan_enabled")</span><input type="checkbox" disabled @(AsBool(GetPath(cfg, "advanced", "loan", "enabled"), false) ? "checked" : null) /></label>
                                <label class="metric-row"><span class="metric-key">@Context.T("rulesets.form.insurance_enabled")</span><input type="checkbox" disabled @(AsBool(GetPath(cfg, "advanced", "insurance", "enabled"), false) ? "checked" : null) /></label>
                                <label class="metric-row"><span class="metric-key">@Context.T("rulesets.form.saving_goal_enabled")</span><input type="checkbox" disabled @(AsBool(GetPath(cfg, "advanced", "saving_goal", "enabled"), false) ? "checked" : null) /></label>
                            </div>
                        </div>
                    </div>
                }
            </section>
        </div>
    }
</section>
