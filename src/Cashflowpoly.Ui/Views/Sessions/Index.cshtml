@* Fungsi file: Merender tampilan Razor untuk bagian Sessions/Index.cshtml beserta interaksi presentasinya. *@
@model Cashflowpoly.Ui.Models.SessionListViewModel

@{
    ViewData["Title"] = Context.T("nav.sessions");
    var isInstructor = Context.Session.IsInstructor();
    var totalSessions = Model.Items.Count;
    var startedCount = Model.Items.Count(x => string.Equals(x.Status, "STARTED", StringComparison.OrdinalIgnoreCase));
    var createdCount = Model.Items.Count(x => string.Equals(x.Status, "CREATED", StringComparison.OrdinalIgnoreCase));
    var endedCount = Model.Items.Count(x => string.Equals(x.Status, "ENDED", StringComparison.OrdinalIgnoreCase));
    var guideTitle = isInstructor
        ? Context.T("sessions.index.guide_title.instructor")
        : Context.T("sessions.index.guide_title.player");
    var guideSteps = isInstructor
        ? new[]
        {
            Context.T("sessions.index.guide.instructor.step1"),
            Context.T("sessions.index.guide.instructor.step2"),
            Context.T("sessions.index.guide.instructor.step3"),
            Context.T("sessions.index.guide.instructor.step4")
        }
        : new[]
        {
            Context.T("sessions.index.guide.player.step1"),
            Context.T("sessions.index.guide.player.step2"),
            Context.T("sessions.index.guide.player.step3"),
            Context.T("sessions.index.guide.player.step4")
        };
    var listTitle = isInstructor
        ? Context.T("sessions.index.list_title.instructor")
        : Context.T("sessions.index.list_title.player");
    var listSubtitle = isInstructor
        ? Context.T("sessions.index.list_subtitle.instructor")
        : Context.T("sessions.index.list_subtitle.player");
}

<section class="section-shell w-full">
    <div class="page-intro">
        <div class="page-intro-main">
            <p class="eyebrow">@(isInstructor ? Context.T("sessions.management") : Context.T("sessions.player_management"))</p>
            <h1 class="headline">@(isInstructor ? Context.T("sessions.title") : Context.T("sessions.player_title"))</h1>
            <p class="subhead">@(isInstructor
                ? Context.T("sessions.subtitle")
                : Context.T("sessions.player_subtitle"))</p>
        </div>
        <div class="page-intro-actions">
            <div class="badge @(isInstructor ? "badge-amber" : "badge-emerald")">@(isInstructor ? Context.T("sessions.live_log") : Context.T("sessions.readonly"))</div>
        </div>
    </div>

    <div class="mt-4 sessions-index-guide-shell" aria-label="@guideTitle">
        <p class="sessions-index-guide-title">@guideTitle</p>
        <ol class="sessions-index-guide">
            @foreach (var step in guideSteps)
            {
                <li>@step</li>
            }
        </ol>
    </div>

    <div class="mt-6 ruleset-unified sessions-index-shell">
        <section class="sessions-index-section">
            <div class="ruleset-section-head">
                <p class="ruleset-section-title">@Context.T("sessions.index.summary_title")</p>
                <p class="ruleset-section-subtitle">@Context.T("sessions.index.summary_subtitle")</p>
            </div>
            <div class="session-stats-grid mt-3">
                <div class="stat-card session-total-card">
                    <p class="text-xs uppercase text-slate-500">@(isInstructor ? Context.T("sessions.total_sessions") : Context.T("sessions.my_sessions"))</p>
                    <p class="mt-2 text-2xl font-semibold text-slate-900">@totalSessions</p>
                </div>
                <div class="stat-card">
                    <p class="text-xs uppercase text-slate-500">@Context.T("sessions.started")</p>
                    <p class="mt-2 text-2xl font-semibold text-slate-900">@startedCount</p>
                </div>
                <div class="stat-card">
                    <p class="text-xs uppercase text-slate-500">@Context.T("sessions.created")</p>
                    <p class="mt-2 text-2xl font-semibold text-slate-900">@createdCount</p>
                </div>
                <div class="stat-card">
                    <p class="text-xs uppercase text-slate-500">@Context.T("sessions.ended")</p>
                    <p class="mt-2 text-2xl font-semibold text-slate-900">@endedCount</p>
                </div>
            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="mt-4 alert alert-error" aria-live="polite">
                @Model.ErrorMessage
            </div>
        }

        <section class="sessions-index-section mt-4">
            <div class="ruleset-section-head">
                <p class="ruleset-section-title">@(isInstructor ? Context.T("sessions.tips.instructor.title") : Context.T("sessions.tips.player.title"))</p>
                <p class="ruleset-section-subtitle">@Context.T("sessions.index.status_help")</p>
            </div>
            <details class="mt-3 data-toggle">
                <summary>@(isInstructor ? Context.T("sessions.tips.instructor.title") : Context.T("sessions.tips.player.title"))</summary>
                <div class="mt-3 metric-panel">
                    <div class="metric-list">
                        @if (isInstructor)
                        {
                            <div class="metric-row"><span class="metric-key">@Context.T("sessions.step") 1</span><span class="metric-value">@Context.T("sessions.tips.instructor.step1")</span></div>
                            <div class="metric-row"><span class="metric-key">@Context.T("sessions.step") 2</span><span class="metric-value">@Context.T("sessions.tips.instructor.step2")</span></div>
                            <div class="metric-row"><span class="metric-key">@Context.T("sessions.step") 3</span><span class="metric-value">@Context.T("sessions.tips.instructor.step3")</span></div>
                        }
                        else
                        {
                            <div class="metric-row"><span class="metric-key">@Context.T("sessions.step") 1</span><span class="metric-value">@Context.T("sessions.tips.player.step1")</span></div>
                            <div class="metric-row"><span class="metric-key">@Context.T("sessions.step") 2</span><span class="metric-value">@Context.T("sessions.tips.player.step2")</span></div>
                            <div class="metric-row"><span class="metric-key">@Context.T("sessions.step") 3</span><span class="metric-value">@Context.T("sessions.tips.player.step3")</span></div>
                        }
                    </div>
                </div>
            </details>

            <div class="mt-4 ux-legend" aria-label="@Context.T("sessions.legend.title")">
                <p class="ux-legend-title">@Context.T("sessions.legend.title")</p>
                <div class="ux-legend-items">
                    <span class="ux-legend-item">
                        <span class="status-pill status-active">@Context.TSessionStatus("STARTED")</span>
                        <span class="ux-legend-note">@Context.T("sessions.legend.started_hint")</span>
                    </span>
                    <span class="ux-legend-item">
                        <span class="status-pill status-draft">@Context.TSessionStatus("CREATED")</span>
                        <span class="ux-legend-note">@Context.T("sessions.legend.created_hint")</span>
                    </span>
                    <span class="ux-legend-item">
                        <span class="status-pill status-retired">@Context.TSessionStatus("ENDED")</span>
                        <span class="ux-legend-note">@Context.T("sessions.legend.ended_hint")</span>
                    </span>
                </div>
            </div>
        </section>

        <section class="sessions-index-section mt-5">
            <div class="ruleset-section-head">
                <p class="ruleset-section-title">@listTitle</p>
                <p class="ruleset-section-subtitle">@listSubtitle</p>
            </div>
            <div class="mt-3 table-wrap">
                <table class="w-full text-left text-sm mobile-card-table">
                    <thead class="table-head">
                        <tr>
                            <th class="px-4 py-3">@Context.T("common.name")</th>
                            <th class="px-4 py-3">@Context.T("common.mode")</th>
                            <th class="px-4 py-3">@Context.T("common.status")</th>
                            <th class="px-4 py-3">@Context.T("common.created")</th>
                            <th class="px-4 py-3 text-right">@Context.T("common.action")</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (Model.Items.Count == 0)
                    {
                        <tr>
                            <td class="px-4 py-4 text-slate-500 mobile-card-empty" colspan="5">@Context.T("state.no_sessions")</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model.Items)
                        {
                            var modeLabel = Context.TRulesetMode(item.Mode);
                            <tr class="border-t border-slate-200">
                                <td class="px-4 py-3 font-medium text-slate-900" data-label="@Context.T("common.name")">@item.SessionName</td>
                                <td class="px-4 py-3 text-slate-600" data-label="@Context.T("common.mode")">@modeLabel</td>
                                <td class="px-4 py-3 text-slate-600" data-label="@Context.T("common.status")">
                                    @{
                                        var statusClass = string.Equals(item.Status, "STARTED", StringComparison.OrdinalIgnoreCase)
                                            ? "status-active"
                                            : string.Equals(item.Status, "CREATED", StringComparison.OrdinalIgnoreCase)
                                                ? "status-draft"
                                                : "status-retired";
                                    }
                                    <span class="status-pill @statusClass">@Context.TSessionStatus(item.Status)</span>
                                </td>
                                <td class="px-4 py-3 text-slate-600" data-label="@Context.T("common.created")">@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="px-4 py-3 text-right" data-label="@Context.T("common.action")">
                                    <a class="table-link"
                                       asp-controller="Sessions" asp-action="Details" asp-route-sessionId="@item.SessionId">@(isInstructor ? Context.T("common.detail") : Context.T("sessions.view_progress"))</a>
                                </td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </section>
    </div>
</section>
