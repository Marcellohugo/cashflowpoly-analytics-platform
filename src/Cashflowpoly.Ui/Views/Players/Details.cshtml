@* Fungsi file: Merender tampilan Razor untuk bagian Players/Details.cshtml beserta interaksi presentasinya. *@
@using System.Globalization
@using System.Text.Json
@using Cashflowpoly.Ui.Infrastructure
@model Cashflowpoly.Ui.Models.PlayerDetailViewModel

@{
    ViewData["Title"] = Context.T("players.detail_title");

    string LocalizeTransactionDetail(string rawDetail)
    {
        return PlayerMetricLabelFormatter.LocalizeTransactionDetail(rawDetail, Context.T);
    }

    (string Title, string Json)? BuildMergedRowChart(
        string domainTitle,
        IEnumerable<(string Path, string Value)> rows,
        bool isRawDomain)
    {
        return PlayerMetricChartPayloadBuilder.BuildMergedRowChart(domainTitle, rows, isRawDomain, Context.T);
    }

    static List<(string Path, string Value)> MergeUniqueRows(params IEnumerable<(string Path, string Value)>[] rowSets)
    {
        return PlayerMetricCollectionHelper.MergeUniqueRows(rowSets);
    }

    static List<(string Path, string Value)> GetGroupRows(
        Dictionary<string, List<(string Path, string Value)>> source,
        params string[] keys)
    {
        return PlayerMetricCollectionHelper.GetGroupRows(source, keys);
    }

    static List<(string Path, string Value)> FilterRowsByKeywords(
        IEnumerable<(string Path, string Value)> rows,
        params string[] keywords)
    {
        return PlayerMetricCollectionHelper.FilterRowsByKeywords(rows, keywords);
    }

    static List<(string Title, string Json)> MergeUniqueCharts(params IEnumerable<(string Title, string Json)>[] chartSets)
    {
        return PlayerMetricCollectionHelper.MergeUniqueCharts(chartSets);
    }

    static List<(string Title, string Json)> FilterChartsByKeywords(
        IEnumerable<(string Title, string Json)> charts,
        params string[] keywords)
    {
        return PlayerMetricCollectionHelper.FilterChartsByKeywords(charts, keywords);
    }

    List<(string Title, string Json)> BuildSectionCharts(
        string domainTitle,
        List<(string Path, string Value)> rows,
        List<(string Title, string Json)> baseCharts,
        int maxCharts = 4,
        bool isRawDomain = false)
    {
        var chartCandidates = new List<(string Title, string Json)>();
        var mergedChart = BuildMergedRowChart(domainTitle, rows, isRawDomain);
        if (mergedChart.HasValue)
        {
            chartCandidates.Add(mergedChart.Value);
        }

        chartCandidates.AddRange(baseCharts);
        var charts = MergeUniqueCharts(chartCandidates);
        if (charts.Count > maxCharts)
        {
            return charts.Take(maxCharts).ToList();
        }

        return charts;
    }

    static List<(string Title, string Json)> GetGroupCharts(
        Dictionary<string, List<(string Title, string Json)>> source,
        params string[] keys)
    {
        return PlayerMetricCollectionHelper.GetGroupCharts(source, keys);
    }

    List<(string Title, string Json)> BuildLineChartsForGroup(string groupKey, JsonElement groupElement, bool isRawDomain)
    {
        return PlayerMetricChartPayloadBuilder.BuildLineChartsForGroup(groupKey, groupElement, isRawDomain, Context.T);
    }

    static int ResolvePlayerAvatarIndex(int turnOrder)
    {
        if (turnOrder <= 0)
        {
            return 1;
        }

        return ((turnOrder - 1) % 4) + 1;
    }

    var trueText = Context.T("state.true");
    var falseText = Context.T("state.false");
    var nullText = Context.T("state.null");
    var rawGroups = PlayerMetricJsonMapper.BuildMetricGroups(Model.GameplayRaw, trueText, falseText, nullText);
    var derivedGroups = PlayerMetricJsonMapper.BuildMetricGroups(Model.GameplayDerived, trueText, falseText, nullText);
    var rawGroupMap = rawGroups.ToDictionary(item => item.GroupKey, item => item.Rows, StringComparer.OrdinalIgnoreCase);
    var derivedGroupMap = derivedGroups.ToDictionary(item => item.GroupKey, item => item.Rows, StringComparer.OrdinalIgnoreCase);
    var rawGroupElementMap = PlayerMetricJsonMapper.BuildMetricGroupElements(Model.GameplayRaw);
    var derivedGroupElementMap = PlayerMetricJsonMapper.BuildMetricGroupElements(Model.GameplayDerived);
    var rawGroupChartsMap = rawGroupElementMap.ToDictionary(
        item => item.Key,
        item => BuildLineChartsForGroup(item.Key, item.Value, true),
        StringComparer.OrdinalIgnoreCase);
    var derivedGroupChartsMap = derivedGroupElementMap.ToDictionary(
        item => item.Key,
        item => BuildLineChartsForGroup(item.Key, item.Value, false),
        StringComparer.OrdinalIgnoreCase);

    var mappedRawKeys = new HashSet<string>(
        new[] { "coins", "ingredients", "meal_orders", "needs", "donations", "gold", "pension", "life_risk", "financial_goals", "actions", "turns" },
        StringComparer.OrdinalIgnoreCase);
    var rawFallbackKeys = rawGroupMap.Keys.Where(key => !mappedRawKeys.Contains(key)).ToArray();

    var part11Rows = MergeUniqueRows(
        GetGroupRows(rawGroupMap, "turns"),
        GetGroupRows(rawGroupMap, rawFallbackKeys));
    var part11Charts = MergeUniqueCharts(
        GetGroupCharts(rawGroupChartsMap, "turns"),
        GetGroupCharts(rawGroupChartsMap, rawFallbackKeys));

    var rawSections = new List<(string Title, string Description, List<(string Title, string Json)> Charts)>
    {
        (
            Context.T("players.details.raw.coin_finance.title"),
            Context.T("players.details.raw.coin_finance.desc"),
            BuildSectionCharts(
                Context.T("players.details.raw.coin_finance.title"),
                GetGroupRows(rawGroupMap, "coins"),
                GetGroupCharts(rawGroupChartsMap, "coins"),
                maxCharts: 5,
                isRawDomain: true)),
        (
            Context.T("players.details.raw.ingredients.title"),
            Context.T("players.details.raw.ingredients.desc"),
            BuildSectionCharts(
                Context.T("players.details.raw.ingredients.title"),
                GetGroupRows(rawGroupMap, "ingredients"),
                GetGroupCharts(rawGroupChartsMap, "ingredients"),
                maxCharts: 5,
                isRawDomain: true)),
        (
            Context.T("players.details.raw.meal_orders.title"),
            Context.T("players.details.raw.meal_orders.desc"),
            BuildSectionCharts(
                Context.T("players.details.raw.meal_orders.title"),
                GetGroupRows(rawGroupMap, "meal_orders"),
                GetGroupCharts(rawGroupChartsMap, "meal_orders"),
                maxCharts: 5,
                isRawDomain: true)),
        (
            Context.T("players.details.raw.needs.title"),
            Context.T("players.details.raw.needs.desc"),
            BuildSectionCharts(
                Context.T("players.details.raw.needs.title"),
                GetGroupRows(rawGroupMap, "needs"),
                GetGroupCharts(rawGroupChartsMap, "needs"),
                maxCharts: 5,
                isRawDomain: true)),
        (
            Context.T("players.details.raw.donations.title"),
            Context.T("players.details.raw.donations.desc"),
            BuildSectionCharts(
                Context.T("players.details.raw.donations.title"),
                GetGroupRows(rawGroupMap, "donations"),
                GetGroupCharts(rawGroupChartsMap, "donations"),
                maxCharts: 5,
                isRawDomain: true)),
        (
            Context.T("players.details.raw.gold.title"),
            Context.T("players.details.raw.gold.desc"),
            BuildSectionCharts(
                Context.T("players.details.raw.gold.title"),
                GetGroupRows(rawGroupMap, "gold"),
                GetGroupCharts(rawGroupChartsMap, "gold"),
                maxCharts: 5,
                isRawDomain: true)),
        (
            Context.T("players.details.raw.pension.title"),
            Context.T("players.details.raw.pension.desc"),
            BuildSectionCharts(
                Context.T("players.details.raw.pension.title"),
                GetGroupRows(rawGroupMap, "pension"),
                GetGroupCharts(rawGroupChartsMap, "pension"),
                maxCharts: 5,
                isRawDomain: true)),
        (
            Context.T("players.details.raw.life_risk.title"),
            Context.T("players.details.raw.life_risk.desc"),
            BuildSectionCharts(
                Context.T("players.details.raw.life_risk.title"),
                GetGroupRows(rawGroupMap, "life_risk"),
                GetGroupCharts(rawGroupChartsMap, "life_risk"),
                maxCharts: 5,
                isRawDomain: true)),
        (
            Context.T("players.details.raw.financial_goals.title"),
            Context.T("players.details.raw.financial_goals.desc"),
            BuildSectionCharts(
                Context.T("players.details.raw.financial_goals.title"),
                GetGroupRows(rawGroupMap, "financial_goals"),
                GetGroupCharts(rawGroupChartsMap, "financial_goals"),
                maxCharts: 5,
                isRawDomain: true)),
        (
            Context.T("players.details.raw.actions.title"),
            Context.T("players.details.raw.actions.desc"),
            BuildSectionCharts(
                Context.T("players.details.raw.actions.title"),
                GetGroupRows(rawGroupMap, "actions"),
                GetGroupCharts(rawGroupChartsMap, "actions"),
                maxCharts: 5,
                isRawDomain: true)),
        (
            Context.T("players.details.raw.turns.title"),
            Context.T("players.details.raw.turns.desc"),
            BuildSectionCharts(
                Context.T("players.details.raw.turns.title"),
                part11Rows,
                part11Charts,
                maxCharts: 5,
                isRawDomain: true))
    };

    var derivedSummaryRows = GetGroupRows(derivedGroupMap, "summary");

    var financialDerivedRows = MergeUniqueRows(
        FilterRowsByKeywords(
            derivedSummaryRows,
            "net_worth",
            "income_diversification",
            "expense_management",
            "business_profit",
            "business_efficiency",
            "gold_roi",
            "growth_pattern"),
        GetGroupRows(derivedGroupMap, "expense_management_components"));

    var strategicDerivedRows = MergeUniqueRows(
        FilterRowsByKeywords(
            derivedSummaryRows,
            "risk_appetite",
            "debt_leverage",
            "debt_ratio",
            "loan_repayment",
            "goal_setting_ambition",
            "risk_exposure",
            "risk_mitigation"),
        GetGroupRows(derivedGroupMap, "risk_appetite_components"));

    var behaviorDerivedRows = FilterRowsByKeywords(
        derivedSummaryRows,
        "action_efficiency",
        "meal_order_success",
        "planning_horizon",
        "donation_aggressiveness",
        "donation_stability");

    var flourishingDerivedRows = MergeUniqueRows(
        FilterRowsByKeywords(
            derivedSummaryRows,
            "fulfillment_diversity",
            "donation_commitment",
            "mission_achievement"),
        GetGroupRows(derivedGroupMap, "happiness_portfolio"));

    var mappedDerivedPaths = new HashSet<string>(
        financialDerivedRows
            .Concat(strategicDerivedRows)
            .Concat(behaviorDerivedRows)
            .Concat(flourishingDerivedRows)
            .Select(row => row.Path),
        StringComparer.OrdinalIgnoreCase);
    var fallbackDerivedRows = derivedSummaryRows.Where(row => !mappedDerivedPaths.Contains(row.Path)).ToList();
    if (fallbackDerivedRows.Count > 0)
    {
        behaviorDerivedRows = MergeUniqueRows(behaviorDerivedRows, fallbackDerivedRows);
    }

    var derivedSections = new List<(string Title, string Description, List<(string Title, string Json)> Charts)>
    {
        (
            Context.T("players.details.derived.financial.title"),
            Context.T("players.details.derived.financial.desc"),
            BuildSectionCharts(
                Context.T("players.details.derived.financial.title"),
                financialDerivedRows,
                FilterChartsByKeywords(
                    GetGroupCharts(derivedGroupChartsMap, "summary", "expense_management_components"),
                    "net", "income", "expense", "business", "gold", "growth"),
                maxCharts: 4)),
        (
            Context.T("players.details.derived.strategy.title"),
            Context.T("players.details.derived.strategy.desc"),
            BuildSectionCharts(
                Context.T("players.details.derived.strategy.title"),
                strategicDerivedRows,
                FilterChartsByKeywords(
                    GetGroupCharts(derivedGroupChartsMap, "summary", "risk_appetite_components"),
                    "risk", "debt", "goal", "loan"),
                maxCharts: 4)),
        (
            Context.T("players.details.derived.behavior.title"),
            Context.T("players.details.derived.behavior.desc"),
            BuildSectionCharts(
                Context.T("players.details.derived.behavior.title"),
                behaviorDerivedRows,
                FilterChartsByKeywords(
                    GetGroupCharts(derivedGroupChartsMap, "summary"),
                    "action", "meal", "order", "planning", "donation"),
                maxCharts: 4)),
        (
            Context.T("players.details.derived.flourishing.title"),
            Context.T("players.details.derived.flourishing.desc"),
            BuildSectionCharts(
                Context.T("players.details.derived.flourishing.title"),
                flourishingDerivedRows,
                FilterChartsByKeywords(
                    GetGroupCharts(derivedGroupChartsMap, "summary", "happiness_portfolio"),
                    "fulfillment", "mission", "happiness", "donation"),
                maxCharts: 4))
    };

    var cashflowJourney = Model.CashflowJourney;
    var hasCashflowJourney = cashflowJourney is not null && cashflowJourney.TransactionCount > 0;
    var localizedTimelineLabels = hasCashflowJourney
        ? cashflowJourney!.TimelineLabels
            .Select(label => string.Equals(label, "START", StringComparison.OrdinalIgnoreCase)
                ? Context.T("common.start")
                : label)
            .ToList()
        : new List<string>();
    var localizedTransactionDetails = hasCashflowJourney
        ? cashflowJourney!.TransactionDetails.Select(LocalizeTransactionDetail).ToList()
        : new List<string>();
    var cashflowJourneyChartPayload = hasCashflowJourney
        ? JsonSerializer.Serialize(new
        {
            chartType = "line",
            labels = localizedTimelineLabels,
            keys = new[] { "cashflow_running_net" },
            formulas = localizedTransactionDetails,
            detailLabel = Context.T("players.details.transaction_label"),
            series = new[]
            {
                new
                {
                    name = Context.T("players.cashflow_journey.series_name"),
                    values = cashflowJourney!.RunningNetSeries
                }
            }
        })
        : "{}";

    var hasGameplayData = Model.GameplayDerived.HasValue || Model.GameplayRaw.HasValue;
    var playerTurnOrder = Model.Summary?.JoinOrder ?? 1;
    var playerAvatarPath = $"/images/players/{ResolvePlayerAvatarIndex(playerTurnOrder)}.png";
    var detailGuideSteps = new[]
    {
        Context.T("players.detail.guide_step1"),
        Context.T("players.detail.guide_step2"),
        Context.T("players.detail.guide_step3"),
        Context.T("players.detail.guide_step4")
    };
}

<section class="section-shell player-detail-overhaul">
    <div class="player-detail-hero">
        <p class="eyebrow text-emerald-700">@Context.T("players.analytics_title")</p>
        <h1 class="headline">@Context.T("players.detail_title")</h1>
        @if (!string.IsNullOrWhiteSpace(Model.PlayerDisplayName))
        {
            <div class="mt-2 flex items-center gap-3">
                <img class="h-8 w-8 rounded-full border border-slate-200 object-cover"
                     src="@playerAvatarPath"
                     alt="@($"{Context.T("common.turn_order")} {playerTurnOrder}")" />
                <p class="player-detail-name" style="margin-top: 0;">@Model.PlayerDisplayName</p>
            </div>
        }
        <div class="player-detail-meta">
            <span class="player-detail-meta__item player-detail-meta__item--mono">@Model.PlayerId</span>
            @if (Model.GameplayComputedAt.HasValue)
            {
                <span class="player-detail-meta__item">@Context.T("common.computed"): @Model.GameplayComputedAt.Value.ToString("dd/MM/yyyy HH:mm")</span>
            }
        </div>
    </div>

    <div class="action-toolbar mt-4 player-detail-toolbar">
        <a class="btn-ghost"
           asp-controller="PlayerDirectory"
           asp-action="Index">@Context.T("players.detail.nav_back_players")</a>
        <a class="btn-ghost"
           asp-controller="Sessions"
           asp-action="Details"
           asp-route-sessionId="@Model.SessionId">@Context.T("players.detail.nav_back_session")</a>
    </div>

    <div class="player-detail-guide-shell mt-4" aria-label="@Context.T("players.detail.guide_title")">
        <p class="player-detail-guide-title">@Context.T("players.detail.guide_title")</p>
        <ol class="player-detail-guide">
            @foreach (var step in detailGuideSteps)
            {
                <li>@step</li>
            }
        </ol>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="mt-4 alert alert-error" aria-live="polite">
            @Model.ErrorMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.GameplayErrorMessage))
    {
        <div class="mt-4 alert alert-warning" aria-live="polite">
            @Model.GameplayErrorMessage
        </div>
    }

    <div id="cashflow-journey" class="players-fusion-metrics player-detail-section">
        <div class="players-fusion-head">
            <div class="page-intro-main">
                <p class="eyebrow">@Context.T("players.cashflow_journey.badge")</p>
                <h2 class="headline text-xl">@Context.T("players.cashflow_journey.title")</h2>
                <p class="subhead text-sm">@Context.T("players.cashflow_journey.subtitle")</p>
            </div>
        </div>

        @if (!hasCashflowJourney)
        {
            <div class="mt-4 alert alert-info">
                @Context.T("players.cashflow_journey.empty")
            </div>
        }
        else
        {
            <div class="mt-6 grid gap-4 md:grid-cols-3 xl:grid-cols-4">
                <article class="stat-card">
                    <p class="text-sm font-medium text-slate-600">@Context.T("players.cashflow_journey.starting_cash")</p>
                    <p class="mt-2 text-2xl font-semibold text-slate-900">@cashflowJourney!.StartingCash.ToString("N0", CultureInfo.CurrentCulture)</p>
                </article>
                <article class="stat-card">
                    <p class="text-sm font-medium text-slate-600">@Context.T("players.cashflow_journey.total_transactions")</p>
                    <p class="mt-2 text-2xl font-semibold text-slate-900">@cashflowJourney.TransactionCount</p>
                </article>
                <article class="stat-card">
                    <p class="text-sm font-medium text-slate-600">@Context.T("players.cashflow_journey.total_in")</p>
                    <p class="mt-2 text-2xl font-semibold text-emerald-700">@cashflowJourney.TotalCashIn.ToString("N0", CultureInfo.CurrentCulture)</p>
                </article>
                <article class="stat-card">
                    <p class="text-sm font-medium text-slate-600">@Context.T("players.cashflow_journey.total_out")</p>
                    <p class="mt-2 text-2xl font-semibold text-rose-700">@cashflowJourney.TotalCashOut.ToString("N0", CultureInfo.CurrentCulture)</p>
                </article>
                <article class="stat-card">
                    <p class="text-sm font-medium text-slate-600">@Context.T("players.cashflow_journey.net")</p>
                    <p class="mt-2 text-2xl font-semibold text-slate-900">@cashflowJourney.NetCashflow.ToString("N0", CultureInfo.CurrentCulture)</p>
                </article>
                <article class="stat-card">
                    <p class="text-sm font-medium text-slate-600">@Context.T("players.cashflow_journey.ending_cash")</p>
                    <p class="mt-2 text-2xl font-semibold text-slate-900">@cashflowJourney.EndingCash.ToString("N0", CultureInfo.CurrentCulture)</p>
                </article>
                <article class="stat-card">
                    <p class="text-sm font-medium text-slate-600">@Context.T("players.cashflow_journey.running_peak")</p>
                    <p class="mt-2 text-2xl font-semibold text-slate-900">@cashflowJourney.PeakRunningNet.ToString("N0", CultureInfo.CurrentCulture)</p>
                </article>
                <article class="stat-card">
                    <p class="text-sm font-medium text-slate-600">@Context.T("players.cashflow_journey.running_lowest")</p>
                    <p class="mt-2 text-2xl font-semibold text-slate-900">@cashflowJourney.LowestRunningNet.ToString("N0", CultureInfo.CurrentCulture)</p>
                </article>
            </div>

            <div class="mt-3 alert alert-info text-sm">
                @(string.Format(
                    CultureInfo.CurrentCulture,
                    Context.T("players.cashflow_journey.quick_check"),
                    cashflowJourney.StartingCash.ToString("N0", CultureInfo.CurrentCulture),
                    cashflowJourney.TotalCashIn.ToString("N0", CultureInfo.CurrentCulture),
                    cashflowJourney.TotalCashOut.ToString("N0", CultureInfo.CurrentCulture),
                    cashflowJourney.EndingCash.ToString("N0", CultureInfo.CurrentCulture)))
            </div>

            <div class="mt-4 metric-panel">
                <div class="metric-list">
                    <div class="metric-row">
                        <span class="metric-key">@Context.T("players.cashflow_journey.period_start")</span>
                        <span class="metric-value">@(cashflowJourney.FirstTransactionAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</span>
                    </div>
                    <div class="metric-row">
                        <span class="metric-key">@Context.T("players.cashflow_journey.period_end")</span>
                        <span class="metric-value">@(cashflowJourney.LastTransactionAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</span>
                    </div>
                    <div class="metric-row">
                        <span class="metric-key">@Context.T("players.cashflow_journey.in_count")</span>
                        <span class="metric-value">@cashflowJourney.CashInCount</span>
                    </div>
                    <div class="metric-row">
                        <span class="metric-key">@Context.T("players.cashflow_journey.out_count")</span>
                        <span class="metric-value">@cashflowJourney.CashOutCount</span>
                    </div>
                </div>
            </div>

            <div class="chart-grid chart-grid-feature mt-4">
                <article class="chart-card chart-card-feature">
                    <h3 class="chart-title">@Context.T("players.cashflow_journey.chart_title")</h3>
                    <svg class="metric-line-chart js-metric-line-chart"
                         viewBox="0 0 840 360"
                         data-chart="@cashflowJourneyChartPayload"
                         role="img"
                         aria-label="@Context.T("players.cashflow_journey.chart_title")"></svg>
                </article>
            </div>
        }
    </div>

    @if (!hasGameplayData)
    {
        <div class="mt-6 alert alert-info" aria-live="polite">
            @Context.T("players.detail.empty_analytics")
        </div>
    }
    else
    {
        <div id="physical-variables" class="players-fusion-metrics player-detail-section">
            <div class="players-fusion-head">
                <div class="page-intro-main">
                    <p class="eyebrow">@Context.T("gameplay.raw")</p>
                    <h2 class="headline text-xl">@Context.T("players.details.raw_title")</h2>
                    <p class="subhead text-sm">@Context.T("players.details.raw_subtitle")</p>
                </div>
            </div>

            <div class="metric-domain-layout mt-6">
                @foreach (var domain in rawSections)
                {
                    <article class="metric-domain-card metric-domain-card-flat">
                        <div class="metric-domain-heading">
                            <h3>@domain.Title</h3>
                            <span class="metric-domain-count">@domain.Charts.Count @Context.T("players.details.chart_count_suffix")</span>
                        </div>
                        <p class="metric-domain-intro">@domain.Description</p>
                        @if (domain.Charts.Count == 0)
                        {
                            <p class="metric-domain-empty">@Context.T("players.details.chart_domain_empty")</p>
                        }
                        else
                        {
                            var summaryChart = domain.Charts.FirstOrDefault(chart =>
                                chart.Title.Contains("Ringkasan Gabungan", StringComparison.OrdinalIgnoreCase) ||
                                chart.Title.Contains("Combined Snapshot", StringComparison.OrdinalIgnoreCase));
                            var hasSummaryChart = !string.IsNullOrWhiteSpace(summaryChart.Title);
                            var detailCharts = hasSummaryChart
                                ? domain.Charts.Where(chart =>
                                    !string.Equals(chart.Title, summaryChart.Title, StringComparison.OrdinalIgnoreCase))
                                    .ToList()
                                : domain.Charts;
                            if (hasSummaryChart)
                            {
                                <div class="chart-grid chart-grid-feature mt-4">
                                    <article class="chart-card chart-card-feature">
                                        <h3 class="chart-title">@summaryChart.Title</h3>
                                        <svg class="metric-line-chart js-metric-line-chart"
                                             viewBox="0 0 840 360"
                                             data-chart="@summaryChart.Json"
                                             role="img"
                                             aria-label="@summaryChart.Title"></svg>
                                    </article>
                                </div>
                            }
                            if (detailCharts.Count > 0)
                            {
                                <div class="chart-scroll-region mt-4"
                                     role="region"
                                     aria-label="@Context.T("players.details.chart_scroll_region")">
                                    <p class="chart-scroll-hint">@Context.T("players.details.chart_scroll_hint")</p>
                                    <div class="chart-grid chart-grid-scroll mt-2">
                                        @foreach (var chart in detailCharts)
                                        {
                                            <article class="chart-card">
                                                <h3 class="chart-title">@chart.Title</h3>
                                                <svg class="metric-line-chart js-metric-line-chart"
                                                     viewBox="0 0 840 360"
                                                     data-chart="@chart.Json"
                                                     role="img"
                                                     aria-label="@chart.Title"></svg>
                                            </article>
                                        }
                                    </div>
                                </div>
                            }
                        }
                    </article>
                }
            </div>
        </div>

        <div id="derived-metrics" class="players-fusion-metrics player-detail-section">
            <div class="players-fusion-head">
                <div class="page-intro-main">
                    <p class="eyebrow">@Context.T("gameplay.derived")</p>
                    <h2 class="headline text-xl">@Context.T("players.details.derived_title")</h2>
                    <p class="subhead text-sm">@Context.T("players.details.derived_subtitle")</p>
                </div>
            </div>

            <div class="metric-domain-layout mt-6">
                @foreach (var domain in derivedSections)
                {
                    <article class="metric-domain-card metric-domain-card-flat">
                        <div class="metric-domain-heading">
                            <h3>@domain.Title</h3>
                            <span class="metric-domain-count">@domain.Charts.Count @Context.T("players.details.chart_count_suffix")</span>
                        </div>
                        <p class="metric-domain-intro">@domain.Description</p>
                        @if (domain.Charts.Count == 0)
                        {
                            <p class="metric-domain-empty">@Context.T("players.details.chart_domain_empty")</p>
                        }
                        else
                        {
                            var summaryChart = domain.Charts.FirstOrDefault(chart =>
                                chart.Title.Contains("Ringkasan Gabungan", StringComparison.OrdinalIgnoreCase) ||
                                chart.Title.Contains("Combined Snapshot", StringComparison.OrdinalIgnoreCase));
                            var hasSummaryChart = !string.IsNullOrWhiteSpace(summaryChart.Title);
                            var detailCharts = hasSummaryChart
                                ? domain.Charts.Where(chart =>
                                    !string.Equals(chart.Title, summaryChart.Title, StringComparison.OrdinalIgnoreCase))
                                    .ToList()
                                : domain.Charts;
                            if (hasSummaryChart)
                            {
                                <div class="chart-grid chart-grid-feature mt-4">
                                    <article class="chart-card chart-card-feature">
                                        <h3 class="chart-title">@summaryChart.Title</h3>
                                        <svg class="metric-line-chart js-metric-line-chart"
                                             viewBox="0 0 840 360"
                                             data-chart="@summaryChart.Json"
                                             role="img"
                                             aria-label="@summaryChart.Title"></svg>
                                    </article>
                                </div>
                            }
                            if (detailCharts.Count > 0)
                            {
                                <div class="chart-scroll-region mt-4"
                                     role="region"
                                     aria-label="@Context.T("players.details.chart_scroll_region")">
                                    <p class="chart-scroll-hint">@Context.T("players.details.chart_scroll_hint")</p>
                                    <div class="chart-grid chart-grid-scroll mt-2">
                                        @foreach (var chart in detailCharts)
                                        {
                                            <article class="chart-card">
                                                <h3 class="chart-title">@chart.Title</h3>
                                                <svg class="metric-line-chart js-metric-line-chart"
                                                     viewBox="0 0 840 360"
                                                     data-chart="@chart.Json"
                                                     role="img"
                                                     aria-label="@chart.Title"></svg>
                                            </article>
                                        }
                                    </div>
                                </div>
                            }
                        }
                    </article>
                }
            </div>
        </div>
    }
</section>

@section Scripts {
    <script>
        window.cashflowpolyPlayerDetailCharts = {
            tooltipText: {
                metric: @Html.Raw(JsonSerializer.Serialize(Context.T("players.details.metric"))),
                series: @Html.Raw(JsonSerializer.Serialize(Context.T("players.details.series"))),
                points: @Html.Raw(JsonSerializer.Serialize(Context.T("players.details.points_value"))),
                formula: @Html.Raw(JsonSerializer.Serialize(Context.T("players.details.source_calc_label"))),
                defaultFormula: @Html.Raw(JsonSerializer.Serialize(Context.T("players.details.source_calc_default"))),
                selectedDetail: @Html.Raw(JsonSerializer.Serialize(Context.T("players.details.selected_detail"))),
                tapHint: @Html.Raw(JsonSerializer.Serialize(Context.T("players.details.tap_hint"))),
                itemPrefix: @Html.Raw(JsonSerializer.Serialize(Context.T("players.details.item")))
            },
            chartStatusText: {
                noSeries: @Html.Raw(JsonSerializer.Serialize(Context.T("players.details.no_series"))),
                noPoints: @Html.Raw(JsonSerializer.Serialize(Context.T("players.details.no_points"))),
                invalidPayload: @Html.Raw(JsonSerializer.Serialize(Context.T("players.details.invalid_payload")))
            }
        };
    </script>
    <script src="~/js/player-detail-charts.js" asp-append-version="true"></script>
}

